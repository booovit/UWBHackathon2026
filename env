VITE_FIREBASE_AUTH_DOMAIN=hackathonproject-4bd31.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=hackathonproject-4bd31
VITE_FIREBASE_STORAGE_BUCKET=hackathonproject-4bd31.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=216621022534
VITE_FIREBASE_APP_ID=1:216621022534:web:fe8ad9c6cc8a88dbbb3947


{
  "name": "studylift-functions",
  "private": true,
  "version": "0.1.0",
  "description": "Firebase Cloud Functions for the Studylift accessibility-first AI study platform.",
  "main": "lib/index.js",
  "type": "commonjs",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "tsc --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^6.6.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.6.0"
  }
}

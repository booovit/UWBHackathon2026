# Frontend Firebase web config.
# Copy this file to `.env.local` and fill in the values from your Firebase project.
# Firebase console -> Project settings -> General -> Your apps -> SDK setup and configuration.
# The `VITE_` prefix is required so Vite exposes these variables to the client.
# These are NOT the Gemini API key. Gemini lives in functions/.secret.local instead.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional. Set to "true" to point the client at the Firebase emulators.
VITE_USE_EMULATORS=false

# Optional. Cloud Functions region. Defaults to us-central1.
VITE_FUNCTIONS_REGION=us-central1
